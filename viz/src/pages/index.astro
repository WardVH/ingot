---
import "../styles/global.css";
import App from "../components/App";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="An as-of time machine for the golden-record temporal pass." />
    <title>Temporal pass — as-of time machine</title>
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <h1>The golden-record <span class="accent">time machine</span></h1>
        <p>
          Drag a date and watch entity 422156's golden record materialize at the moment its identity
          becomes resolvable — then see the over-merge guard <i>flag</i> a late bridge instead of
          merging. Every projection comes from the real Elixir <code>Temporal</code> engine.
        </p>
      </header>

      <App client:load />
    </main>
  </body>
</html>
