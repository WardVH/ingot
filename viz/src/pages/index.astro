---
import "../styles/global.css";
import Story from "../components/Story";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="The golden-record way of working, told as a guided story." />
    <title>Golden records — the story</title>
  </head>
  <body>
    <main class="shell">
      <header class="masthead">
        <h1>Golden records, <span class="accent">as a story</span></h1>
        <p>
          Six chapters: why destructive merging fails, how <b>code-anchored claims</b> make the golden
          record a <i>derived</i> thing, how priority resolves disagreement, and why even a wrong merge is
          <b>cheap</b>. Advance with <code>→</code> (or click); <code>1</code>–<code>6</code> jump chapters.
          Every engine chapter replays real output from <code>mix run demo_export.exs</code>. The standalone
          scenes live at <a href="/machine">/machine</a> and <a href="/guard">/guard</a>.
        </p>
      </header>

      <Story client:load />
    </main>
  </body>
</html>
