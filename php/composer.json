{
    "name": "ingot/golden-record-php",
    "description": "PHP port of the golden-record engine (422156 fold path) — TDD parity port + Elixir/PHP benchmark",
    "type": "project",
    "require": {
        "php": ">=8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "GoldenRecord\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GoldenRecord\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
